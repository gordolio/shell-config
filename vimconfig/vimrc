" JSON path function for statusline
function! GetJsonPath()
  if &filetype != 'json'
    return ''
  endif
  
  let line = getline('.')
  let col = col('.')
  let lnum = line('.')
  
  " Find all opening braces/brackets before current position
  let path = []
  let brace_stack = []
  let in_string = 0
  let in_key = 0
  let current_key = ''
  
  " Go through each line from start to current position
  for l in range(1, lnum)
    let text = getline(l)
    if l == lnum
      let text = strpart(text, 0, col - 1)
    endif
    
    let i = 0
    while i < len(text)
      let char = text[i]
      
      " Handle string detection
      if char == '"' && (i == 0 || text[i-1] != '\')
        let in_string = !in_string
        if in_string
          let current_key = ''
          let in_key = 1
        elseif in_key
          let in_key = 0
        endif
      elseif in_string && in_key
        let current_key .= char
      elseif !in_string
        if char == '{'
          call add(brace_stack, {'type': 'object', 'key': ''})
        elseif char == '['
          call add(brace_stack, {'type': 'array', 'index': -1})
        elseif char == ':'
          if len(brace_stack) > 0 && brace_stack[-1]['type'] == 'object'
            let brace_stack[-1]['key'] = current_key
          endif
        elseif char == ',' || char == '}'
          if len(brace_stack) > 0 && brace_stack[-1]['type'] == 'array'
            let brace_stack[-1]['index'] += 1
          endif
        elseif char == '}' || char == ']'
          if len(brace_stack) > 0
            call remove(brace_stack, -1)
          endif
        endif
      endif
      let i += 1
    endwhile
  endfor
  
  " Build path string
  let path_parts = []
  for item in brace_stack
    if item['type'] == 'object' && item['key'] != ''
      call add(path_parts, item['key'])
    elseif item['type'] == 'array'
      call add(path_parts, '[' . max([0, item['index']]) . ']')
    endif
  endfor
  
  return len(path_parts) > 0 ? '.' . join(path_parts, '.') : ''
endfunction

function! HLNext (blinktime)
  let [bufnum, lnum, col, off] = getpos('.')
  let matchlen = strlen(matchstr(strpart(getline('.'),col-1),@/))
  let target_pat = '\c\%#'.@/
  let blinks = 3
  for n in range(1, blinks)
    let red = matchadd('WhiteOnRed', target_pat, 101)
    redraw
    exec 'sleep ' . float2nr(a:blinktime / (2*blinks) * 1000) . 'm'
    call matchdelete(red)
    redraw
    exec 'sleep ' . float2nr(a:blinktime / (2*blinks) * 1000) . 'm'
  endfor
endfunction


