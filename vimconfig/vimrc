function JsonTidy(line1,line2)
  let text = join(getline(a:line1, a:line2),'')
  let text = substitute(text,"'\([^']*\)'",'"\1"','g')
  let text = substitute(text,"\(, \|{\)\([a-zA-Z_]*\):",'\1"\2":','g')
  let text = substitute(text,', }',' }','g')
  let tempfile = substitute(system("mktemp /tmp/vimtidy.XXXX"),'\n','','')
  call writefile([text],tempfile)
  execute a:line1.",".a:line2." ! cat ".tempfile." | node ~/.vim/json_tidy.js"
  call system("rm ".tempfile)
endfunction

function JsonlTidy(line1,line2)
  let lines = getline(a:line1, a:line2)
  let output = []

  for line in lines
    " Skip empty lines
    if line =~ '^\s*$'
      continue
    endif

    " Format each JSON line
    let tempfile = substitute(system("mktemp /tmp/vimtidy.XXXX"),'\n','','')
    call writefile([line],tempfile)
    let formatted = system("cat ".tempfile." | node ~/.vim/json_tidy.js")
    call system("rm ".tempfile)

    " Remove trailing newline from formatted output
    let formatted = substitute(formatted, '\n$', '', '')

    " Add the formatted JSON to output
    let output += split(formatted, '\n')

    " Add blank line separator
    call add(output, '')
  endfor

  " Remove the final blank line if it exists
  if len(output) > 0 && output[-1] == ''
    call remove(output, -1)
  endif

  " Replace the range with formatted output
  execute a:line1.",".a:line2."delete"
  call append(a:line1 - 1, output)
endfunction

