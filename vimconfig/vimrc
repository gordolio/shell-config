" Auto-open Neo-tree in git repositories
function AutoNeoTree()
  if argc() == 0 && isdirectory('.git')
    execute 'set columns=' . (g:editor_width + g:neotree_width)
    Neotree show
  elseif argc() == 1 && isdirectory(argv()[0])
    execute 'set columns=' . (g:editor_width + g:neotree_width)
    execute 'Neotree show dir=' . argv()[0]
  else
    execute 'set columns=' . (g:editor_width)
  endif
endfunction

